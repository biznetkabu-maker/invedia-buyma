# --- BUYMA 自動化 ---

# Google Sheets
# BUYMA_SPREADSHEET_ID=your_buyma_spreadsheet_id
# BUYMA_WORKSHEET_NAME=02_Purchase_Control

# 認証（credentials.json が無い場合のみ）
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# BUYMA 設定
# BUYMA_PRICE_FACTOR=0.97
# BUYMA_FEE_RATE=0.077
# CUSTOMS_RATE=0.10
# SHIPPING_COST_JPY=2000
# TARGET_PROFIT_RATE=0.15

# 漏斗（方針A）
# INTAKE_FUNNEL=1
# INTAKE_WEEKLY_LIMIT=40
# INTAKE_REQUIRE_STYLE=1
# INTAKE_OFFICIAL_PRADA=1

# 仕入先 URL キャッシュ
# SUPPLY_URL_CACHE=1
# SUPPLY_URL_CACHE_TTL_DAYS=90

# LINE 通知
# LINE_NOTIFY_TOKEN=
# LINE_PROFIT_THRESHOLD=30000

# 運用モード
# OPERATION_MODE=monitor
# AUTO_FOREX=true

# プロキシ（スクレイパー用）
# BRIGHTDATA_CUSTOMER=
# BRIGHTDATA_ZONE=residential
# BRIGHTDATA_PASSWORD=
# SMARTPROXY_USER=
# SMARTPROXY_PASSWORD=
