# --- BUYMA 自動化 ---

# Google Sheets
# SPREADSHEET_ID=your_spreadsheet_id
# WORKSHEET_NAME=02_Purchase_Control

# 認証（credentials.json が無い場合のみ）
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
# CREDENTIALS_PATH=credentials.json

# BUYMA アカウント
# BUYMA_EMAIL=
# BUYMA_PASSWORD=
# BUYMA_PRICE_FACTOR=0.97
# BUYMA_FEE_RATE=0.077

# 利益計算
# CUSTOMS_RATE=0.10
# SHIPPING_COST_JPY=2000
# TARGET_PROFIT_RATE=0.10
# HIGH_PROFIT_THRESHOLD=0.20
# MEDIUM_PROFIT_THRESHOLD=0.10

# 漏斗（方針A）
# INTAKE_FUNNEL=1
# INTAKE_WEEKLY_LIMIT=40
# INTAKE_REQUIRE_STYLE=1
# INTAKE_OFFICIAL_PRADA=1

# 仕入先 URL キャッシュ
# SUPPLY_URL_CACHE=1
# SUPPLY_URL_CACHE_TTL_DAYS=90

# LINE 通知
# LINE_CHANNEL_ACCESS_TOKEN=
# LINE_USER_ID=
# LINE_NOTIFY_TOKEN=
# LINE_PROFIT_THRESHOLD=30000

# 運用モード
# OPERATION_MODE=monitor
# AUTO_FOREX=true
# FOREX_UPDATE_SHEET=false
# PRIORITY_TIER=auto
# UNKNOWN_ALERT_THRESHOLD=3

# スクレイパー
# SCRAPER_CONCURRENCY=3
# SCRAPER_HEADLESS=true
# SCRAPER_TIMEOUT_MS=30000
# SCRAPER_MAX_RETRIES=2

# プロキシ（スクレイパー用）
# BRIGHTDATA_CUSTOMER=lum-customer-XXXXX
# BRIGHTDATA_ZONE=residential
# BRIGHTDATA_PASSWORD=
# SMARTPROXY_USER=
# SMARTPROXY_PASSWORD=
# PROXY_LIST=
